NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

SUPABASE_SECRET_KEY=sb_secret_xxx

# Used by auth flows for email-confirm and OAuth redirect URLs. Must
# match the deployed origin. Locally this is http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Only needed when running scripts/seed-admin.ts. Leave unset in
# production deploys.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_USERNAME=
ADMIN_LEAGUE_ID=

# Anthropic API key — powers the AI narrative summary on the multi-team
# trade analyzer (Pro feature). Server-side only; never exposed to the
# client. If unset, the analyzer renders the numeric verdicts without
# a narrative.
ANTHROPIC_API_KEY=
# Optional model override. Defaults to claude-haiku-4-5 — small, fast,
# cheap, well-suited to a ~150-word trade explainer. Set this to pin a
# specific version or to point at a newer Haiku as Anthropic ships
# them. See https://docs.anthropic.com/en/docs/about-claude/models for
# the current model list.
ANTHROPIC_MODEL=claude-haiku-4-5
